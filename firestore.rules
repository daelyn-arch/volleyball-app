rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /matches/{matchId} {
      // Dashboard reads require auth
      allow read: if request.auth != null;

      // Admins can delete matches
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Scoring app writes via REST API (no auth) — validate shape
      allow create, update: if
        request.resource.data.keys().hasAll(['id', 'homeTeam', 'awayTeam', 'events', 'config', 'matchComplete'])
        && request.resource.data.matchComplete == true
        && request.resource.data.id == matchId;
    }
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null && request.auth.uid == uid && request.resource.data.role == 'viewer';
      allow update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
